generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  password  String
  role      String    @default("employee")
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  todos     Todo[]
  notes     Note[]
}

model Todo {
  id        String   @id @default(cuid())
  text      String
  done      Boolean  @default(false)
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Note {
  id        String     @id @default(cuid())
  title     String
  desc      String?    @db.NVarChar(Max)
  done      Boolean    @default(false)
  createdAt DateTime   @default(now())

  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  progress  Progress[]
}

model Progress {
  id        String     @id @default(cuid())
  act       String     @db.NVarChar(Max)
  tglAct    DateTime?
  status    String     @default("Plan")
  createdAt DateTime   @default(now())

  noteId    String
  note      Note       @relation(fields: [noteId], references: [id], onDelete: Cascade)
  feedbacks Feedback[]
}

model Feedback {
  id          String    @id @default(cuid())
  text        String    @db.NVarChar(Max)
  tglFeedback DateTime?
  createdAt   DateTime  @default(now())

  progressId  String
  progress    Progress  @relation(fields: [progressId], references: [id], onDelete: Cascade)
}

// ─── EXPATRIATE MODULE ────────────────────────────────────────────────────────

// Managed via /expatriate/permit-types page.
// hasExpiry: false      → expiryDate not required
// isOneTime: true       → issued once, expiry date shown but NOT counted as urgency when expired (e.g. eVisa)
// isEPO: true           → one per person, marks departure / permit closure
// forExpat/forFamily control which dropdowns the type appears in
model PermitType {
  id                 String   @id @default(cuid())
  name               String   @unique
  description        String?  @db.NVarChar(Max)
  forExpat           Boolean  @default(true)
  forFamily          Boolean  @default(true)
  hasExpiry          Boolean  @default(true)
  isOneTime          Boolean  @default(false)
  isEPO              Boolean  @default(false)
  linkedToWorkPermit Boolean  @default(false)
  order              Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  expatPermits  ExpatPermit[]
  familyPermits FamilyPermit[]
}

model Expatriate {
  id                 String   @id @default(cuid())
  name               String
  birthPlace         String
  birthDate          DateTime
  gender             String
  passportNo         String
  passportIssuedDate DateTime
  passportExpiryDate DateTime
  position           String
  department         String
  presentAddress     String   @db.NVarChar(Max)
  permanentAddress   String   @db.NVarChar(Max)
  arrivalDate        DateTime
  renewalNo          Int?
  photoUrl           String?  @db.NVarChar(500)
  passportScanUrl    String?  @db.NVarChar(500)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  permits   ExpatPermit[]
  families  ExpatFamily[]
  histories ExpatHistory[]
}

model ExpatPermit {
  id             String    @id @default(cuid())
  expatId        String
  permitTypeId   String
  number         String
  issuedDate     DateTime
  expiryDate     DateTime?
  status         String    @default("active")
  renewedFromId  String?
  scanUrl        String?   @db.NVarChar(500)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  expat      Expatriate         @relation(fields: [expatId], references: [id], onDelete: Cascade)
  permitType PermitType         @relation(fields: [permitTypeId], references: [id])
  histories  ExpatPermitHistory[]
}

// familyStatus examples: "Wife" | "Husband" | "Child"
model ExpatFamily {
  id                 String   @id @default(cuid())
  expatId            String
  name               String
  gender             String
  birthPlace         String
  birthDate          DateTime
  passportNo         String
  passportIssuedDate DateTime
  passportExpiryDate DateTime
  familyStatus       String
  arrivalDate        DateTime
  photoUrl           String?  @db.NVarChar(500)
  passportScanUrl    String?  @db.NVarChar(500)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  expat     Expatriate           @relation(fields: [expatId], references: [id], onDelete: Cascade)
  permits   FamilyPermit[]
  histories ExpatFamilyHistory[]
}

model FamilyPermit {
  id            String    @id @default(cuid())
  familyId      String
  permitTypeId  String
  number        String
  issuedDate    DateTime
  expiryDate    DateTime?
  status        String    @default("active")
  renewedFromId String?
  scanUrl       String?   @db.NVarChar(500)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  family     ExpatFamily          @relation(fields: [familyId], references: [id], onDelete: Cascade)
  permitType PermitType           @relation(fields: [permitTypeId], references: [id])
  histories  FamilyPermitHistory[]
}

// ─── HISTORY TABLES ───────────────────────────────────────────────────────────
// changes: JSON string { "field": { "before": "...", "after": "..." } }
// changedBy: User.id (not FK-linked for simplicity)

model ExpatHistory {
  id        String     @id @default(cuid())
  expatId   String
  action    String
  changes   String     @db.NVarChar(Max)
  changedAt DateTime   @default(now())
  changedBy String

  expat     Expatriate @relation(fields: [expatId], references: [id], onDelete: Cascade)
}

model ExpatPermitHistory {
  id        String      @id @default(cuid())
  permitId  String
  action    String
  changes   String      @db.NVarChar(Max)
  changedAt DateTime    @default(now())
  changedBy String

  permit    ExpatPermit @relation(fields: [permitId], references: [id], onDelete: Cascade)
}

model ExpatFamilyHistory {
  id        String      @id @default(cuid())
  familyId  String
  action    String
  changes   String      @db.NVarChar(Max)
  changedAt DateTime    @default(now())
  changedBy String

  family    ExpatFamily @relation(fields: [familyId], references: [id], onDelete: Cascade)
}

model FamilyPermitHistory {
  id        String      @id @default(cuid())
  permitId  String
  action    String
  changes   String      @db.NVarChar(Max)
  changedAt DateTime    @default(now())
  changedBy String

  permit    FamilyPermit @relation(fields: [permitId], references: [id], onDelete: Cascade)
}
